<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Start screen -->
    <LinearLayout
        android:id="@+id/startContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/startButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Start" />
    </LinearLayout>

    <!-- Main controls screen -->
    <LinearLayout
        android:id="@+id/controlsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- D-pad column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/dpadUp"
                android:layout_width="180dp"
                android:layout_height="64dp"
                android:text="UP" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/dpadLeft"
                    android:layout_width="180dp"
                    android:layout_height="64dp"
                    android:text="LEFT" />

                <Button
                    android:id="@+id/dpadStop"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginHorizontal="12dp"
                    android:text="STOP" />

                <Button
                    android:id="@+id/dpadRight"
                    android:layout_width="180dp"
                    android:layout_height="64dp"
                    android:text="RIGHT" />
            </LinearLayout>

            <Button
                android:id="@+id/dpadDown"
                android:layout_width="180dp"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:text="DOWN" />
        </LinearLayout>

        <!-- Labels column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Labels"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/backToStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back" />
            </LinearLayout>

            <!-- 4 rows x 2 columns -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/label1"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:text="Label 1" />

                    <Button
                        android:id="@+id/label2"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Label 2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/label3"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:text="Label 3" />

                    <Button
                        android:id="@+id/label4"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Label 4" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/label5"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:text="Label 5" />

                    <Button
                        android:id="@+id/label6"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Label 6" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/label7"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:text="Label 7" />

                    <Button
                        android:id="@+id/label8"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Label 8" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>